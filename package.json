{
  "name": "narrative-review",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:static": "vite build --config static/vite.config.mts",
    "build:action": "ncc build action/index.ts -o dist-action && cp dist-static/index.html dist-action/template.html",
    "build:all": "npm run build:static && npm run build:action",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "diff2html": "^3.4.56",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@eslint/js": "^9.14.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.1",
    "vite-plugin-singlefile": "^2.3.2"
  }
