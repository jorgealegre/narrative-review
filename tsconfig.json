{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "action/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "static/**/*.ts",
    "static/**/*.tsx",
    "static/**/*.mts"
  ],
  "exclude": ["node_modules", "dist-action", "dist-static"]
}
