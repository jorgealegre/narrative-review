{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "../dist-action",
    "rootDir": "..",
    "paths": {
      "@/*": ["../src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "../src/lib/**/*.ts"]
}
